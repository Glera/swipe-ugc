{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime-release-host-verification.v1.schema.json",
  "title": "Trusted verification of a deployed runtime release",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "releaseId",
    "descriptorHash",
    "origin",
    "indexLocator",
    "sidecarLocator",
    "runtimeArtifactDigest",
    "indexDigest",
    "sidecarDigest",
    "probe",
    "verifiedAt",
    "evidenceDigest"
  ],
  "properties": {
    "schema": { "const": "runtime-release-host-verification.v1" },
    "releaseId": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "descriptorHash": { "$ref": "#/$defs/rawDigest" },
    "origin": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^https://[^/?#@]+$|^http://(?:127\\.0\\.0\\.1|localhost|\\[::1\\])(?::[0-9]+)?$"
    },
    "indexLocator": { "type": "string", "minLength": 1, "maxLength": 1024 },
    "sidecarLocator": { "type": "string", "minLength": 1, "maxLength": 1024 },
    "runtimeArtifactDigest": { "$ref": "#/$defs/prefixedDigest" },
    "indexDigest": { "$ref": "#/$defs/prefixedDigest" },
    "sidecarDigest": { "$ref": "#/$defs/prefixedDigest" },
    "probe": { "const": "trusted-host-probe.v1" },
    "verifiedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
    },
    "evidenceDigest": { "$ref": "#/$defs/rawDigest" }
  },
  "$defs": {
    "rawDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "prefixedDigest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
