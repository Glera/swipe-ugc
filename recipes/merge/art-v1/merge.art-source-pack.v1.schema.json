{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://p4g.local/schemas/merge.art-source-pack.v1.schema.json",
  "title": "Merge Raster Art Source Pack v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "artPackHash", "templateContractDigest", "providerPolicyDigest", "world", "budgetReceipt", "sources"],
  "properties": {
    "schema": { "const": "merge.art-source-pack.v1" },
    "artPackHash": { "$ref": "#/$defs/digest" },
    "templateContractDigest": { "$ref": "#/$defs/digest" },
    "providerPolicyDigest": { "$ref": "#/$defs/digest" },
    "world": {
      "type": "object",
      "additionalProperties": false,
      "required": ["worldId", "title", "visualThesis", "palette", "promptProfile"],
      "properties": {
        "worldId": { "type": "string", "pattern": "^[a-z][a-z0-9-]{2,31}$" },
        "title": { "type": "string", "minLength": 1, "maxLength": 80 },
        "visualThesis": { "type": "string", "minLength": 20, "maxLength": 500 },
        "palette": { "type": "array", "minItems": 4, "maxItems": 8, "uniqueItems": true, "items": { "type": "string", "pattern": "^#[0-9A-F]{6}$" } },
        "promptProfile": { "type": "string", "minLength": 20, "maxLength": 2000 }
      }
    },
    "budgetReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "calls", "marginalCostMicros", "priceKnown"],
      "properties": {
        "provider": { "const": "openai.builtin-imagegen.v1" },
        "calls": { "type": "integer", "minimum": 1, "maximum": 9 },
        "marginalCostMicros": { "const": 0 },
        "priceKnown": { "const": true }
      }
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backgroundPortrait", "backgroundLandscape", "generator", "lockStage1", "lockStage2", "chain1Sheet", "chain2Sheet", "chain3Sheet", "chain4Sheet"],
      "properties": {
        "backgroundPortrait": { "$ref": "#/$defs/source" },
        "backgroundLandscape": { "$ref": "#/$defs/source" },
        "generator": { "$ref": "#/$defs/source" },
        "lockStage1": { "$ref": "#/$defs/source" },
        "lockStage2": { "$ref": "#/$defs/source" },
        "chain1Sheet": { "$ref": "#/$defs/source" },
        "chain2Sheet": { "$ref": "#/$defs/source" },
        "chain3Sheet": { "$ref": "#/$defs/source" },
        "chain4Sheet": { "$ref": "#/$defs/source" }
      }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "bytes", "width", "height", "promptDigest"],
      "properties": {
        "path": { "type": "string", "pattern": "^generated/[a-zA-Z0-9._/-]+\\.(png|webp)$" },
        "sha256": { "$ref": "#/$defs/digest" },
        "bytes": { "type": "integer", "minimum": 64, "maximum": 62914560 },
        "width": { "type": "integer", "minimum": 256, "maximum": 4096 },
        "height": { "type": "integer", "minimum": 256, "maximum": 4096 },
        "promptDigest": { "$ref": "#/$defs/digest" }
      }
    }
  }
}
